# LAMMPS NPT Production Run Template
# Adjust parameters as needed for your system

# === INITIALIZATION ===
units           real
atom_style      full
boundary        p p p

# === STRUCTURE ===
read_restart    equilibrated.restart

# === FORCE FIELD ===
# Modify pair_style and coefficients for your system
pair_style      lj/cut 12.0
pair_modify     mix arithmetic

# Example pair coefficients (REPLACE WITH YOUR PARAMETERS)
# pair_coeff      type1 type2 epsilon sigma

# === SETTINGS ===
neighbor        2.0 bin
neigh_modify    delay 0 every 1 check yes

# === ENSEMBLE ===
# NPT at 300 K, 1 atm
fix             1 all npt temp 300.0 300.0 100.0 iso 1.0 1.0 1000.0

# === TIMESTEP ===
timestep        1.0  # 1 fs for real units

# === OUTPUT ===
thermo          1000
thermo_style    custom step temp pe ke etotal press vol density

# Trajectory for analysis
dump            1 all custom 1000 production.lammpstrj id type x y z

# Per-atom properties if needed
# compute         msd all msd
# fix             msd_out all ave/time 1000 1 1000 c_msd[4] file msd.dat

# === RUN ===
run             1000000  # 1 ns production

# === SAVE STATE ===
write_restart   production.restart
write_data      production.data
