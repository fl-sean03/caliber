&CONTROL
    calculation = 'relax'
    prefix = 'material'
    outdir = './tmp'
    pseudo_dir = './pseudo'
    verbosity = 'high'
    forc_conv_thr = 1.0d-4
/

&SYSTEM
    ibrav = 0
    nat = 2
    ntyp = 1
    ecutwfc = 40.0
    ecutrho = 320.0
    occupations = 'smearing'
    smearing = 'gaussian'
    degauss = 0.01
/

&ELECTRONS
    conv_thr = 1.0d-8
    mixing_beta = 0.7
/

&IONS
    ion_dynamics = 'bfgs'
/

CELL_PARAMETERS angstrom
   5.430000   0.000000   0.000000
   0.000000   5.430000   0.000000
   0.000000   0.000000   5.430000

ATOMIC_SPECIES
Si  28.086  Si.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS crystal
Si   0.00   0.00   0.00
Si   0.25   0.25   0.25

K_POINTS automatic
4 4 4 0 0 0
