# =============================================================================
# Caliber - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Internal/private documentation (not for public repo)
# -----------------------------------------------------------------------------
internal/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# Configuration with secrets (never commit)
# -----------------------------------------------------------------------------
config.yaml
.env

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.log
input_tmp.in
CRASH

# -----------------------------------------------------------------------------
# Simulation outputs (if accidentally created in root)
# -----------------------------------------------------------------------------
*.lammpstrj
*.dump
*.restart
log.lammps
*.xyz

# -----------------------------------------------------------------------------
# Large data files
# -----------------------------------------------------------------------------
*.hdf5
*.h5
*.nc
*.npy
*.npz

# -----------------------------------------------------------------------------
# ML model files (download on demand)
# -----------------------------------------------------------------------------
*.model
*.pt
*.pth
*.ckpt

# -----------------------------------------------------------------------------
# Potential files (download fresh)
# -----------------------------------------------------------------------------
*.eam
*.eam.alloy
*.eam.fs
*.tersoff
*.UPF

# -----------------------------------------------------------------------------
# Run artifacts / scratch (never commit)
# -----------------------------------------------------------------------------
*.pid
pw.out
core.*
